set_global_assignment -name FAMILY "Arria 10"
set_global_assignment -name DEVICE 10AX115U1F45I1SG
set_global_assignment -name TOP_LEVEL_ENTITY dot16_original_top
set_global_assignment -name SYSTEMVERILOG_FILE ../../src/rtl_validation_ops.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../src/dot16_original.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../quartus/dot16_original/dot16_original_top.sv
set_global_assignment -name SDC_FILE dot16_original.sdc
set_global_assignment -name FLOW_DISABLE_ASSEMBLER ON
set_global_assignment -name OPTIMIZATION_MODE "AGGRESSIVE PERFORMANCE"
set_global_assignment -name PHYSICAL_SYNTHESIS_COMBO_LOGIC ON
set_global_assignment -name PHYSICAL_SYNTHESIS_REGISTER_DUPLICATION ON
set_instance_assignment -name VIRTUAL_PIN ON -to *
