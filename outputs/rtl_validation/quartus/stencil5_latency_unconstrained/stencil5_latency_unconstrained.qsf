set_global_assignment -name TOP_LEVEL_ENTITY stencil5_latency_unconstrained_top
set_global_assignment -name SYSTEMVERILOG_FILE ../../src/rtl_validation_ops.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../src/stencil5_latency_unconstrained.sv
