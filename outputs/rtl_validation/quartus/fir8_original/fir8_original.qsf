set_global_assignment -name FAMILY "Arria10"
set_global_assignment -name DEVICE 10AX115U1F45I1SG
set_global_assignment -name TOP_LEVEL_ENTITY fir8_original_top
set_global_assignment -name SYSTEMVERILOG_FILE ../../src/rtl_validation_ops.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../src/fir8_original.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../quartus/fir8_original/fir8_original_top.sv
set_global_assignment -name SDC_FILE fir8_original.sdc
